// ============================================================================
// QUANTUM AI SMART ENTRY PRO — Indicator
// Version      : 2.0.0  (Strict Clean-UI rebuild)
// Pine Script  : v6
// Author       : Quantum AI Systems
// ----------------------------------------------------------------------------
// PURPOSE
//   High-probability, NON-REPAINTING entry indicator tuned for OTC Binary
//   Options on the 1-minute and 5-minute timeframes.
//
// STRICT UI CONTRACT (by design — do not change without intent)
//   The chart stays COMPLETELY clean. The ONLY things drawn are:
//       • a GREEN  BUY  arrow BELOW the candle
//       • a RED    SELL arrow ABOVE the candle
//   Nothing else is ever plotted or drawn: no EMA/SMA/VWAP lines, no RSI/MACD/
//   ADX/ATR/Bollinger sub-plots, no support/resistance, no order blocks, FVGs,
//   liquidity zones, BOS/CHoCH labels, no dashboard, trend/probability labels,
//   volume histogram, market-structure lines, candle-pattern names, background
//   colors, tables, boxes, zones, trendlines, debug text, stats or watermarks.
//
//   Every filter below is computed INTERNALLY but NEVER displayed.
//
// NON-REPAINT GUARANTEES
//   • All decisions use values from CLOSED candles only.
//   • A signal is committed solely on bar close (barstate.isconfirmed), so an
//     arrow can never appear, move or disappear intrabar.
//   • Higher-timeframe data is pulled with lookahead_off + gaps_off and is only
//     ever evaluated at bar close, so it cannot repaint.
//   • Pivots confirm N bars after the fact (inherently non-repainting).
//
// SIGNAL PHILOSOPHY
//   BUY  fires ONLY when EVERY bullish confirmation agrees.
//   SELL fires ONLY when EVERY bearish confirmation agrees.
//   Ranging / sideways markets are actively filtered out.
//   "No signal" is preferred over a low-quality signal.
// ============================================================================

//@version=6
indicator(title      = "Quantum AI Smart Entry Pro",
          shorttitle = "QASEP",
          overlay    = true)

// ============================================================================
// SECTION 1 · INPUTS  (tuning only — nothing here adds chart drawings)
// ============================================================================

// ── Trend / EMA ─────────────────────────────────────────────────────────────
grpTrend   = "Trend Filter"
i_ema_fast = input.int(21,  "Fast EMA Length", minval=1, group=grpTrend)
i_ema_slow = input.int(50,  "Slow EMA Length", minval=1, group=grpTrend)

// ── Momentum / RSI ──────────────────────────────────────────────────────────
grpRsi     = "RSI"
i_rsi_len  = input.int(14,   "RSI Length",      minval=1,  group=grpRsi)
i_rsi_bull = input.float(52, "RSI Bull Level",  minval=50, maxval=100, group=grpRsi)
i_rsi_bear = input.float(48, "RSI Bear Level",  minval=0,  maxval=50,  group=grpRsi)
i_rsi_ob   = input.float(78, "RSI Overbought (skip late longs)",  minval=50, maxval=100, group=grpRsi)
i_rsi_os   = input.float(22, "RSI Oversold (skip late shorts)",   minval=0,  maxval=50,  group=grpRsi)

// ── MACD ──────────────────────────────────────────────────────────────────
grpMacd     = "MACD"
i_macd_fast = input.int(12, "MACD Fast",   minval=1, group=grpMacd)
i_macd_slow = input.int(26, "MACD Slow",   minval=1, group=grpMacd)
i_macd_sig  = input.int(9,  "MACD Signal", minval=1, group=grpMacd)

// ── ADX / Trend Strength ────────────────────────────────────────────────────
grpAdx     = "Trend Strength (ADX)"
i_adx_len  = input.int(14,   "ADX Length",            minval=1, group=grpAdx)
i_adx_min  = input.float(22, "ADX Minimum Threshold", minval=1, group=grpAdx)

// ── Volume ──────────────────────────────────────────────────────────────────
grpVol     = "Volume"
i_use_vol  = input.bool(true, "Require Volume Confirmation",  group=grpVol)
i_vol_len  = input.int(20,    "Volume Average Length", minval=1, group=grpVol)
i_vol_mult = input.float(1.2, "Relative-Volume Threshold (x avg)", minval=0.1, step=0.1, group=grpVol)

// ── Higher-Timeframe Confirmation ───────────────────────────────────────────
grpHtf     = "Higher-Timeframe Confirmation"
i_use_htf  = input.bool(true, "Require HTF Trend Alignment", group=grpHtf)
i_htf      = input.timeframe("5", "Confirmation Timeframe (use 5 for 1m, 15 for 5m)", group=grpHtf)

// ── Sideways / Ranging Filter ─────────────────────────────────────────────
grpRange    = "Sideways / Ranging Filter"
i_use_range = input.bool(true,  "Block signals in ranging markets", group=grpRange)
i_chop_len  = input.int(14,     "Choppiness Index Length", minval=2, group=grpRange)
i_chop_max  = input.float(55,   "Choppiness Ranging Threshold (>)", minval=1, group=grpRange)
i_sep_min   = input.float(0.05, "Min EMA separation % (flat below)", minval=0.0, step=0.01, group=grpRange)
i_atr_len   = input.int(14,     "ATR Length (volatility floor)", minval=1, group=grpRange)
i_atr_avg   = input.int(50,     "ATR Average Length", minval=1, group=grpRange)
i_atr_comp  = input.float(0.8,  "ATR compression factor (atr < avg x => dead)", minval=0.1, step=0.05, group=grpRange)

// ============================================================================
// SECTION 2 · CORE CALCULATIONS  (INTERNAL ONLY — never drawn)
// ----------------------------------------------------------------------------
// Everything resolves on confirmed bars. Built-in ta.* functions use the
// current close; the final signal is additionally gated by
// barstate.isconfirmed so nothing is acted on until the candle closes.
// ============================================================================

// ── 2.1 EMA Trend ─────────────────────────────────────────────────────────
ema_fast  = ta.ema(close, i_ema_fast)
ema_slow  = ta.ema(close, i_ema_slow)
trend_bull = ema_fast > ema_slow and close > ema_fast
trend_bear = ema_fast < ema_slow and close < ema_fast

// ── 2.2 RSI ──────────────────────────────────────────────────────────────
rsi_val  = ta.rsi(close, i_rsi_len)
// Bullish: above bull level, rising, and not already over-extended.
rsi_bull = rsi_val > i_rsi_bull and rsi_val > rsi_val[1] and rsi_val < i_rsi_ob
rsi_bear = rsi_val < i_rsi_bear and rsi_val < rsi_val[1] and rsi_val > i_rsi_os

// ── 2.3 MACD ─────────────────────────────────────────────────────────────
[macd_line, macd_sig_line, macd_hist] = ta.macd(close, i_macd_fast, i_macd_slow, i_macd_sig)
macd_bull = macd_line > macd_sig_line and macd_hist > 0
macd_bear = macd_line < macd_sig_line and macd_hist < 0

// ── 2.4 ATR / Volatility ───────────────────────────────────────────────────
atr_val = ta.atr(i_atr_len)
atr_avg = ta.sma(atr_val, i_atr_avg)
atr_ok  = atr_val >= atr_avg * i_atr_comp   // reject dead / compressed volatility

// ── 2.5 ADX / DMI (manual, v6-safe) ────────────────────────────────────────
up_move  = high - high[1]
dn_move  = low[1] - low
plus_dm  = up_move > dn_move and up_move > 0 ? up_move : 0.0
minus_dm = dn_move > up_move and dn_move > 0 ? dn_move : 0.0
tr_rma   = ta.rma(ta.tr(true), i_adx_len)
plus_di  = tr_rma > 0 ? 100 * ta.rma(plus_dm,  i_adx_len) / tr_rma : 0.0
minus_di = tr_rma > 0 ? 100 * ta.rma(minus_dm, i_adx_len) / tr_rma : 0.0
di_sum   = plus_di + minus_di
dx       = di_sum > 0 ? 100 * math.abs(plus_di - minus_di) / di_sum : 0.0
adx_val  = ta.rma(dx, i_adx_len)
adx_ok   = adx_val >= i_adx_min
di_bull  = plus_di > minus_di
di_bear  = minus_di > plus_di

// ── 2.6 Volume ─────────────────────────────────────────────────────────────
// Many OTC / synthetic feeds report no (or zero) volume. When volume data is
// unavailable, volume confirmation is treated as neutral (never blocks).
vol_sma  = ta.sma(volume, i_vol_len)
has_vol  = not na(vol_sma) and vol_sma > 0
vol_spike = has_vol ? (volume >= vol_sma * i_vol_mult) : true
vol_ok    = not i_use_vol or vol_spike

// ── 2.7 Candle Confirmation ────────────────────────────────────────────────
candle_bull = close > open    // demand candle
candle_bear = close < open    // supply candle

// ── 2.8 Choppiness Index (ranging detector) ────────────────────────────────
chop_hi  = ta.highest(high, i_chop_len)
chop_lo  = ta.lowest(low,  i_chop_len)
chop_sum = math.sum(ta.tr(true), i_chop_len)
chop_rng = chop_hi - chop_lo
chop_idx = chop_rng > 0 ? 100 * math.log10(chop_sum / chop_rng) / math.log10(i_chop_len) : 0.0

// ── 2.9 EMA separation (flat-market detector) ──────────────────────────────
ema_sep_pct = ema_slow > 0 ? math.abs(ema_fast - ema_slow) / ema_slow * 100 : 0.0
ema_flat    = ema_sep_pct < i_sep_min

// ── 2.10 Sideways / Ranging State ───────────────────────────────────────────
// Ranging if trend is weak (low ADX) OR choppiness is high OR EMAs are flat
// OR volatility has collapsed. Any one is enough to stand aside.
is_ranging = i_use_range and (not adx_ok or chop_idx > i_chop_max or ema_flat or not atr_ok)

// ── 2.11 Higher-Timeframe Bias (non-repainting) ─────────────────────────────
[htf_ef, htf_es, htf_c] = request.security(syminfo.tickerid, i_htf,
     [ta.ema(close, i_ema_fast), ta.ema(close, i_ema_slow), close],
     gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
htf_bull = not i_use_htf or (htf_c > htf_es and htf_ef > htf_es)
htf_bear = not i_use_htf or (htf_c < htf_es and htf_ef < htf_es)

// ============================================================================
// SECTION 3 · STRICT SIGNAL LOGIC  (ALL confirmations must agree)
// ----------------------------------------------------------------------------
// A directional "state" is true only when every bullish/bearish filter aligns
// and the market is not ranging. We then emit a discrete signal on the FIRST
// confirmed bar that the alignment occurs (rising edge), so arrows are clean
// one-shot events rather than a continuous run. Finally, barstate.isconfirmed
// guarantees the signal is locked in only after the candle closes.
// ============================================================================

bull_state = trend_bull and rsi_bull and macd_bull and di_bull and adx_ok and vol_ok and candle_bull and htf_bull and not is_ranging
bear_state = trend_bear and rsi_bear and macd_bear and di_bear and adx_ok and vol_ok and candle_bear and htf_bear and not is_ranging

// Rising edge: only the first bar of a fresh alignment qualifies.
bull_edge = bull_state and not bull_state[1]
bear_edge = bear_state and not bear_state[1]

// Final, non-repainting signals — committed strictly on candle close.
buy_signal  = bull_edge and not bear_state and barstate.isconfirmed
sell_signal = bear_edge and not bull_state and barstate.isconfirmed

// ============================================================================
// SECTION 4 · THE ONLY VISUAL OUTPUT  (BUY / SELL arrows)
// ----------------------------------------------------------------------------
// plotshape is used (not labels) so signals are lightweight, fixed in place,
// and can never move or be cleared. Green BUY arrow below the bar; red SELL
// arrow above the bar. This is the entire chart footprint of the indicator.
// ============================================================================
plotshape(buy_signal,
          title    = "BUY Signal",
          style    = shape.triangleup,
          location = location.belowbar,
          color    = color.new(#00e676, 0),
          size     = size.small,
          text     = "BUY",
          textcolor = color.new(#00e676, 0))

plotshape(sell_signal,
          title    = "SELL Signal",
          style    = shape.triangledown,
          location = location.abovebar,
          color    = color.new(#ff1744, 0),
          size     = size.small,
          text     = "SELL",
          textcolor = color.new(#ff1744, 0))

// ============================================================================
// SECTION 5 · ALERTS  (exactly two — nothing else)
// ============================================================================
alertcondition(buy_signal,
               title   = "BUY Signal",
               message = "QASEP BUY Signal | {{ticker}} @ {{close}}")

alertcondition(sell_signal,
               title   = "SELL Signal",
               message = "QASEP SELL Signal | {{ticker}} @ {{close}}")
